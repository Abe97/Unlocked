  "brands": {
    "aura": {
      "name": "AURA",
      "brandIntensity": "full",
      "tagline": {
        "it": "Beyond the sound",
        "en": "Beyond the sound"
      },
      "description": {
        "it": "Boutique event curatoriale che mette in dialogo musica elettronica contemporanea e patrimonio storico. Ogni edizione è un atto curatoriale in luoghi che non hanno bisogno di essere spiegati.",
        "en": "A curatorial boutique event that puts contemporary electronic music in dialogue with historic heritage. Each edition is a curatorial act in places that need no introduction."
      }
    },
    "umf": {
      "name": "Unlocked Music Festival",
      "acronym": "UMF",
      "brandIntensity": "medium",
      "tagline": {
        "it": "Dal tramonto fino a notte fonda",
        "en": "From sunset to deep night"
      },
      "description": {
        "it": "Il festival open-air internazionale di Unlocked. Dal Porto Nuovo di Castellammare del Golfo, una produzione strutturata che porta la scena elettronica mondiale in Sicilia.",
        "en": "Unlocked's international open-air festival. From Porto Nuovo in Castellammare del Golfo, a structured production bringing the global electronic scene to Sicily."
      }
    }
  },
